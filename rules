rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // กฎสำหรับบทความ (อ่านได้ทุกคน แก้ไขเฉพาะแอดมิน)
    match /articles/{article} {
      allow read: if true;
      allow write: if true; // ในช่วงพัฒนาตั้งเป็น true ไว้ก่อนครับ
    }
    // กฎสำหรับคะแนนและคอมเมนต์ (สำคัญมาก: ต้องอนุญาตให้คนทั่วไป create ได้)
    match /ratings/{rating} {
      allow read: if true;
      allow create: if true; 
      allow update, delete: if true; 
    }
  }
}
