<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BBC Church - Admin Center (Complete)</title>
    <link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;700&family=Prompt:wght@400;600&display=swap" rel="stylesheet">
    <style>
        :root { --primary: #4dabff; --bg-black: #000; --card-bg: #111; --success: #27ae60; --danger: #e74c3c; }
        body { background: var(--bg-black); color: #fff; font-family: 'Sarabun', sans-serif; padding: 20px; }
        .container { max-width: 1200px; margin: auto; }
        .admin-card { background: var(--card-bg); padding: 25px; border-radius: 15px; border: 1px solid #333; margin-bottom: 30px; }
        h2 { color: var(--primary); border-bottom: 2px solid var(--primary); padding-bottom: 10px; display: inline-block; }
        .form-section { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 20px; margin-bottom: 20px; }
        input, select, textarea { width: 100%; padding: 12px; background: #1a1a1a; border: 1px solid #333; color: white; border-radius: 8px; }
        .btn-mini { background: var(--primary); border: none; color: white; padding: 5px 15px; border-radius: 8px; cursor: pointer; }
        .btn-mini.del { background: var(--danger); }
        .btn-save { width: 100%; padding: 15px; background: var(--success); border: none; color: white; border-radius: 10px; font-weight: bold; cursor: pointer; }
        
        /* Card Layout */
        .article-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 20px; }
        .article-card { background: #1a1a1a; padding: 15px; border-radius: 12px; border: 1px solid #333; }
        .card-img { width: 100%; height: 160px; object-fit: cover; border-radius: 8px; margin-bottom: 10px; }
    </style>
</head>
<body>

<div class="container">
    <div class="admin-card">
        <h2>✍️ บันทึกบทความ</h2>
        <form id="articleForm">
            <input type="hidden" id="editId">
            <div class="form-section">
                <div><label>วันที่</label><input type="date" id="customDate" required></div>
                <div><label>หมวดหมู่</label><select id="category"><option>🎙️ คำเทศนา</option><option>🌟 คำพยาน</option><option>📖 บทความ</option><option>📢 ข่าวสาร</option></select></div>
                <div class="full-width"><label>หัวข้อเรื่อง</label><input type="text" id="title" required></div>
                <div><label>ผู้แต่ง</label>
                    <div style="display:flex; gap:5px;">
                        <select id="authorSelect"></select>
                        <button type="button" class="btn-mini" id="addAuthorBtn">+</button>
                        <button type="button" class="btn-mini del" id="delAuthorBtn">🗑️</button>
                    </div>
                </div>
                <div><label>รูปปก</label><input type="file" id="fileThumb" accept="image/*"></div>
                <input type="hidden" id="valThumb">
                <div><label>YouTube 1</label><input type="text" id="yt1"></div>
                <div><label>YouTube 2</label><input type="text" id="yt2"></div>
            </div>
            <textarea id="mainContent" rows="5" placeholder="เนื้อหา..."></textarea>
            <button type="submit" class="btn-save" style="margin-top:20px;">🚀 บันทึกข้อมูล</button>
        </form>
    </div>
    <div class="admin-card">
        <h2>📑 รายการเนื้อหา</h2>
        <div id="articleContainer" class="article-grid"></div>
    </div>
</div>

<script type="module">
    import { initializeApp } from "https://www.gstatic.com/firebasejs/10.12.0/firebase-app.js";
    import { getFirestore, collection, addDoc, doc, updateDoc, deleteDoc, onSnapshot, getDoc } from "https://www.gstatic.com/firebasejs/10.12.0/firebase-firestore.js";
    import { getStorage, ref, uploadBytesResumable, getDownloadURL } from "https://www.gstatic.com/firebasejs/10.12.0/firebase-storage.js";

    const db = getFirestore(initializeApp({
        apiKey: "AIzaSyDw9PPAcnoQUcVnHpcndJ5OpBcmYYnMq3",
        projectId: "bbcchurch-6ffc3",
        storageBucket: "bbcchurch-6ffc3.firebasestorage.app",
        appId: "1:1007626508012:web:b936b62bf0ea69b31877c9"
    }));
    const storage = getStorage();

    // ระบบผู้แต่ง
    onSnapshot(collection(db, "authors"), (snap) => {
        const select = document.getElementById("authorSelect");
        select.innerHTML = '<option value="">-- เลือกผู้แต่ง --</option>';
        snap.forEach(d => select.innerHTML += `<option value="${d.data().name}" data-id="${d.id}">${d.data().name}</option>`);
    });

    document.getElementById("addAuthorBtn").onclick = async () => { const n = prompt("ชื่อผู้แต่ง:"); if(n) await addDoc(collection(db, "authors"), { name: n }); };
    document.getElementById("delAuthorBtn").onclick = async () => { 
        const sel = document.getElementById("authorSelect");
        const id = sel.options[sel.selectedIndex]?.dataset.id;
        if(id) await deleteDoc(doc(db, "authors", id));
    };

    // บันทึกข้อมูล
    document.getElementById("articleForm").onsubmit = async (e) => {
        e.preventDefault();
        const file = document.getElementById("fileThumb").files[0];
        let thumbUrl = document.getElementById("valThumb").value;
        if (file) {
            const res = await uploadBytesResumable(ref(storage, 'arts/'+Date.now()), file);
            thumbUrl = await getDownloadURL(res.ref);
        }
        const data = {
            displayDate: document.getElementById("customDate").value,
            category: document.getElementById("category").value,
            title: document.getElementById("title").value,
            authorName: document.getElementById("authorSelect").value,
            yt1: document.getElementById("yt1").value,
            yt2: document.getElementById("yt2").value,
            thumbUrl: thumbUrl,
            mainContent: document.getElementById("mainContent").value
        };
        const id = document.getElementById("editId").value;
        if (id) await updateDoc(doc(db, "articles", id), data);
        else await addDoc(collection(db, "articles"), data);
        window.location.reload();
    };

    // แสดงรายการ
    onSnapshot(collection(db, "articles"), (snap) => {
        const container = document.getElementById("articleContainer");
        container.innerHTML = "";
        snap.forEach(d => {
            const i = d.data();
            container.innerHTML += `
                <div class="article-card">
                    <img src="${i.thumbUrl || 'https://placehold.co/600x400'}" class="card-img">
                    <div class="card-title">${i.title}</div>
                    <div style="font-size:12px; margin-bottom:10px;">📅 ${i.displayDate} | 👤 ${i.authorName}</div>
                    <button onclick="editArt('${d.id}')" class="btn-mini">แก้ไข</button>
                    <button onclick="deleteArt('${d.id}')" class="btn-mini del">ลบ</button>
                </div>`;
        });
    });

    window.editArt = async (id) => {
        const d = (await getDoc(doc(db, "articles", id))).data();
        document.getElementById("editId").value = id;
        document.getElementById("title").value = d.title;
        document.getElementById("customDate").value = d.displayDate;
        document.getElementById("yt1").value = d.yt1 || "";
        document.getElementById("yt2").value = d.yt2 || "";
        document.getElementById("valThumb").value = d.thumbUrl || "";
        window.scrollTo({ top: 0, behavior: 'smooth' });
    };
    window.deleteArt = (id) => deleteDoc(doc(db, "articles", id));
</script>
</body>
</html>
